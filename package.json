{
  "name": "http-accept-language-kit",
  "version": "0.1.0",
  "description": "Parse and format Accept-Language headers with structured diagnostics.",
  "keywords": [
    "http",
    "accept",
    "language",
    "accept-language",
    "locale",
    "i18n",
    "parser",
    "diagnostics",
    "typescript",
    "browser",
    "developer-tools"
  ],
  "type": "module",
  "sideEffects": false,
  "license": "MPL-2.0",
  "author": "Recoveredd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Recoveredd/http-accept-language-kit.git"
  },
  "bugs": {
    "url": "https://github.com/Recoveredd/http-accept-language-kit/issues"
  },
  "homepage": "https://github.com/Recoveredd/http-accept-language-kit#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
